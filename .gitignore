# ==========================================
# 1. SPIRE PROJECT SPECIFIC (Biological Data)
# ==========================================
# NEVER commit raw protein structures or massive hash tables
*.pdb
*.cif
*.json
data/raw/
data/processed/
backend/data/
backend/ml/models/*.pt
backend/ml/models/*.pth

# ==========================================
# 2. NEXT.JS / NODE.JS (Frontend)
# ==========================================
frontend/node_modules/
frontend/.next/
frontend/out/
frontend/build/
.DS_Store
*.local
frontend/.env*

# ==========================================
# 3. PYTHON (Backend & Data Structures)
# ==========================================
__pycache__/
*.py[cod]
*$py.class
*.so
.venv/
venv/
env/
.env
backend/.venv/

# Distribution / packaging
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Unit test / coverage reports
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py.cover
.hypothesis/
.pytest_cache/
.ruff_cache/

# ==========================================
# 4. TOOLS & IDEs
# ==========================================
